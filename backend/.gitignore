# ─── Python bytecode ─────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo

# ─── Virtual environments ─────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ─── Distribution / packaging ─────────────────────────────────────────────────
*.egg-info/
*.egg
dist/
build/
.eggs/

# ─── Secrets & config ─────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── Database ─────────────────────────────────────────────────────────────────
*.db
*.sqlite3

# ─── Alembic ──────────────────────────────────────────────────────────────────
alembic/versions/__pycache__/

# ─── Test / coverage ──────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ─── Uploads (temp files from receipt/statement processing) ───────────────────
uploads/

# ─── Profiling ────────────────────────────────────────────────────────────────
*.prof
*.pstats

# ─── Test reports ─────────────────────────────────────────────────────────────
junit*.xml

# ─── macOS ────────────────────────────────────────────────────────────────────
.DS_Store

# ─── IDE ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/

