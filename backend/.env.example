# ── Database ──────────────────────────────────────────────────────────────────
# asyncpg driver — required for async SQLAlchemy
# For Supabase: use the Session mode pooler URL (port 5432), NOT the direct URL
#   postgresql+asyncpg://postgres.PROJECTREF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
# For local Docker Postgres:
DATABASE_URL=postgresql+asyncpg://helm_user:yourpassword@localhost:5432/helm

# Set true when connecting to Supabase or any remote Postgres that requires SSL.
# asyncpg needs ssl passed via connect_args, not as a URL parameter.
# Leave false for local Docker Postgres (no SSL needed).
DB_SSL_REQUIRED=false

# ── Redis ─────────────────────────────────────────────────────────────────────
# Used for rate limiting and session tracking
REDIS_URL=redis://localhost:6379/0

# ── Auth / JWT ────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── AI — Groq ─────────────────────────────────────────────────────────────────
# Used for: agent LLM (openai/gpt-oss-120b), supervisor routing, PDF statement extraction
# Get key at: https://console.groq.com
GROQ_API_KEY=gsk_...

# ── AI — Google Gemini ────────────────────────────────────────────────────────
# Used for: receipt scanning (photo → structured line items via gemini-2.5-flash)
# Get key at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=AIza...

# ── Push Notifications ────────────────────────────────────────────────────────
EXPO_PUSH_TOKEN_BASE_URL=https://exp.host/--/api/v2/push/send

# ── Runtime ───────────────────────────────────────────────────────────────────
# "development" enables /docs, relaxed CORS; "production" tightens both
ENVIRONMENT=development
